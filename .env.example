# Redis connection
REDIS_URL=redis://redis:6379

# Server config
HOST=0.0.0.0
PORT=3000

# Default clip expiry in seconds (default: 1 hour = 3600)
COPPY_DEFAULT_TTL=3600

# Max TTL in seconds (default: 24 hours = 86400)
COPPY_MAX_TTL=86400

# API token for write operations (leave empty for open-access dev mode)
# Generate one: openssl rand -hex 24
COPPY_API_TOKEN=
